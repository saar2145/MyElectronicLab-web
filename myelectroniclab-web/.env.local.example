# Client-side (בטוח לחשיפה בדפדפן):
NEXT_PUBLIC_SUPABASE_URL=https://viqmlpipgzrfulbauotv.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server-only (לעולם לא NEXT_PUBLIC_ - חשוף רק ב-API Routes):
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Admin panel:
# ADMIN_PASSWORD_HASH = SHA-256 hex של הסיסמה. ליצור עם:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
ADMIN_PASSWORD_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# מחרוזת אקראית וסודית לחתימת session tokens - כל ערך ארוך ואקראי מספיק
ADMIN_SESSION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
